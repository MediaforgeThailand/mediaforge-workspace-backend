# ═══════════════════════════════════════════════════════════════════
# MediaForge Backend — Edge Function Secrets
# Copy to .env and fill in values. Set on Supabase via:
#   npx supabase secrets set KEY=value
# ═══════════════════════════════════════════════════════════════════

# ── Supabase (auto-injected by runtime, but needed for local dev) ─
SUPABASE_URL=https://yonnvlhgwdxkuirhdfaz.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin Auth ────────────────────────────────────────────────────
# Secret for signing/verifying admin JWT tokens (openssl rand -hex 32)
JWT_SECRET=

# ── Stripe (Payments) ────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Kling AI (Video Generation) ──────────────────────────────────
KLING_ACCESS_KEY_ID=
KLING_SECRET_KEY=

# ── Google AI Studio (Image Gen / TTS) ───────────────────────────
GOOGLE_AI_STUDIO_KEY=

# ── OpenAI (Pipeline Execution) ──────────────────────────────────
OPENAI_API_KEY=

# ── Freepik (Stock Images) ───────────────────────────────────────
FREEPIK_API_KEY=

# ── Lovable (Flow Execution Gateway) ─────────────────────────────
LOVABLE_API_KEY=

# ── SendGrid (Transactional Email) ───────────────────────────────
SENDGRID_API_KEY=

# ── PostHog (Analytics) ──────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Thai Bulk SMS (OTP) ──────────────────────────────────────────
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
THAIBULKSMS_SENDER=

# ── Affiliate Bridge ─────────────────────────────────────────────
# Shared secret for erp-affiliate-bridge authentication
BRIDGE_API_KEY=
